{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IronLog Desktop",
  "version": "0.1.0",
  "identifier": "com.ironlog.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IronLog Desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 740
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
